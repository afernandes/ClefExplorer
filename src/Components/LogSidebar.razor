@using System.IO
@using ClefExplorer.Models

<aside class="clef-sidebar">
    <div class="clef-sidebar-pad">
        <OmniPopover Open="_abrirOpen" OpenChanged="@(v => _abrirOpen = v)" ShowArrow="false" Offset="4" Width="240px" Class="clef-abrir-pop">
            <Trigger>
                <OmniButton Text="Abrir" Icon="folder" Variant="ButtonVariant.Primary" Block="true" />
            </Trigger>
            <ChildContent>
                <OmniMenu>
                    <OmniMenuItem Text="Arquivo .clef" Icon="file-text" OnClick="@(() => Exec(() => OnOpenFile.InvokeAsync()))" />
                    <OmniMenuItem Text="Pasta de logs" Icon="folder" OnClick="@(() => Exec(() => OnOpenFolder.InvokeAsync()))" />
                    @if (LogGroups != null && LogGroups.Any())
                    {
                        <OmniMenuSeparator />
                        @foreach (var group in LogGroups)
                        {
                            var g = group;
                            <OmniMenuItem Text="@g.Name" Icon="layers" OnClick="@(() => Exec(() => OnOpenGroup.InvokeAsync(g)))" />
                        }
                    }
                    <OmniMenuSeparator />
                    <OmniMenuItem Text="Gerenciar Grupos" Icon="settings" OnClick="@(() => Exec(() => OnManageGroups.InvokeAsync()))" />
                    <OmniMenuItem Text="Configurações" Icon="sliders" OnClick="@(() => Exec(() => OnOpenSettings.InvokeAsync()))" />
                </OmniMenu>
            </ChildContent>
        </OmniPopover>
    </div>

    <div class="clef-sidebar-scroll">
        <div class="clef-section-label">Filtros Rápidos</div>
        <div class="clef-filters">
            <button type="button" class="clef-filter @(FiltroRapido == "Todos" ? "is-active" : "")" @onclick='() => SetFiltroRapido("Todos")'>
                <OmniIcon Name="inbox" Size="ComponentSize.Sm" />
                <span>Todos</span>
            </button>
            <button type="button" class="clef-filter clef-filter-error @(FiltroRapido == "Error" ? "is-active" : "")" @onclick='() => SetFiltroRapido("Error")'>
                <OmniIcon Name="alert-circle" Size="ComponentSize.Sm" />
                <span>Erros</span>
            </button>
            <button type="button" class="clef-filter clef-filter-warn @(FiltroRapido == "Warning" ? "is-active" : "")" @onclick='() => SetFiltroRapido("Warning")'>
                <OmniIcon Name="alert-triangle" Size="ComponentSize.Sm" />
                <span>Avisos</span>
            </button>
            <button type="button" class="clef-filter clef-filter-info @(FiltroRapido == "Information" ? "is-active" : "")" @onclick='() => SetFiltroRapido("Information")'>
                <OmniIcon Name="info" Size="ComponentSize.Sm" />
                <span>Informações</span>
            </button>
        </div>

        <div class="clef-section-label">Período</div>
        <div class="clef-period">
            <div>
                <div class="clef-field-label">De:</div>
                <OmniDatePicker TValue="DateTime?" Value="DataInicial" ValueChanged="OnDataInicialChanged" Clearable="true" Placeholder="dd/mm/aaaa" />
            </div>
            <div>
                <div class="clef-field-label">Até:</div>
                <OmniDatePicker TValue="DateTime?" Value="DataFinal" ValueChanged="OnDataFinalChanged" Clearable="true" Placeholder="dd/mm/aaaa" />
            </div>
        </div>

        @if (AvailableFiles != null && AvailableFiles.Any())
        {
            <div class="clef-section-label">Arquivos Carregados</div>
            <div class="clef-tree">
                <LogFileTree Files="@AvailableFiles" CheckedFiles="@(VisibleFiles ?? LoadedFiles)" OnSelectionChanged="OnSelectionChanged" />
            </div>
        }
    </div>
</aside>

@code {
    [Parameter] public string FiltroRapido { get; set; } = "Todos";
    [Parameter] public EventCallback<string> FiltroRapidoChanged { get; set; }

    [Parameter] public HashSet<string>? VisibleFiles { get; set; }
    [Parameter] public EventCallback<HashSet<string>?> VisibleFilesChanged { get; set; }

    [Parameter] public DateTime? DataInicial { get; set; }
    [Parameter] public EventCallback<DateTime?> DataInicialChanged { get; set; }

    [Parameter] public DateTime? DataFinal { get; set; }
    [Parameter] public EventCallback<DateTime?> DataFinalChanged { get; set; }

    [Parameter] public IEnumerable<string> LoadedFiles { get; set; } = Enumerable.Empty<string>();
    [Parameter] public IEnumerable<string> AvailableFiles { get; set; } = Enumerable.Empty<string>();
    [Parameter] public IEnumerable<LogGroup> LogGroups { get; set; } = Enumerable.Empty<LogGroup>();

    [Parameter] public EventCallback OnOpenFile { get; set; }
    [Parameter] public EventCallback OnOpenFolder { get; set; }
    [Parameter] public EventCallback<LogGroup> OnOpenGroup { get; set; }
    [Parameter] public EventCallback OnManageGroups { get; set; }
    [Parameter] public EventCallback OnOpenSettings { get; set; }

    private bool _abrirOpen;

    /// <summary>Fecha o popover e dispara a ação do item escolhido.</summary>
    private async Task Exec(Func<Task> action)
    {
        _abrirOpen = false;
        await action();
    }

    private async Task SetFiltroRapido(string filtro)
    {
        FiltroRapido = filtro;
        await FiltroRapidoChanged.InvokeAsync(filtro);
    }

    private async Task OnSelectionChanged(HashSet<string> selectedFiles)
    {
        VisibleFiles = selectedFiles;
        await VisibleFilesChanged.InvokeAsync(VisibleFiles);
    }

    private async Task OnDataInicialChanged(DateTime? value)
    {
        DataInicial = value;
        await DataInicialChanged.InvokeAsync(value);
    }

    private async Task OnDataFinalChanged(DateTime? value)
    {
        DataFinal = value;
        await DataFinalChanged.InvokeAsync(value);
    }
}
