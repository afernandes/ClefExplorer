@using ClefExplorer.Models
@using ClefExplorer.Helpers
@using Serilog.Events
@inject IJSRuntime JSRuntime

<div class="clef-detail">
    @if (SelectedEvent != null)
    {
        <div class="clef-detail-head">
            <div class="clef-detail-meta">
                <OmniBadge Text="@SelectedEvent.Level" Variant="LogLevelStyles.Variant(SelectedEvent.Level)" />
                <span class="clef-detail-meta-item"><OmniIcon Name="calendar" Size="ComponentSize.Sm" /> @SelectedEvent.Timestamp?.ToString("dd/MM/yyyy")</span>
                <span class="clef-detail-meta-item"><OmniIcon Name="clock" Size="ComponentSize.Sm" /> @SelectedEvent.Timestamp?.ToString("HH:mm:ss.fff zzz")</span>
            </div>
            <OmniButton Icon="x" IconOnly="true" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" OnClick="@(() => OnClose.InvokeAsync())" />
        </div>

        <OmniCard Title="Mensagem" Class="clef-detail-card">
            <div class="clef-msg">@TextFormatter.Format(SelectedEvent.Message)</div>
        </OmniCard>

        @if (!string.IsNullOrEmpty(SelectedEvent.Exception))
        {
            <OmniCard Class="clef-detail-card clef-exc-card">
                <HeaderContent>
                    <div class="clef-exc-title"><OmniIcon Name="alert-triangle" Size="ComponentSize.Sm" /> Exceção</div>
                </HeaderContent>
                <HeaderActions>
                    <OmniButton Icon="copy" IconOnly="true" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" OnClick="CopyException" />
                </HeaderActions>
                <ChildContent>
                    <div class="clef-scroll-box">
                        <pre class="clef-pre">@StackTraceHighlighter.Highlight(SelectedEvent.Exception)</pre>
                    </div>
                </ChildContent>
            </OmniCard>
        }

        <OmniCard Title="Propriedades" NoPadding="true" Class="clef-detail-card">
            <table class="clef-prop-table">
                <thead>
                    <tr>
                        <th style="width: 30%">Chave</th>
                        <th>Valor</th>
                    </tr>
                </thead>
                <tbody>
                    @if (SelectedEvent.Properties != null)
                    {
                        @foreach (var p in SelectedEvent.Properties.OrderBy(x => x.Key))
                        {
                            <tr @key="p.Key">
                                <td class="clef-prop-key">@p.Key</td>
                                <td>
                                    @if (p.Key.Contains("StackTrace", StringComparison.OrdinalIgnoreCase) && p.Value is ScalarValue sv && sv.Value is string s)
                                    {
                                        <div class="clef-scroll-box" style="max-height: 300px;">
                                            <pre class="clef-pre">@StackTraceHighlighter.Highlight(s)</pre>
                                        </div>
                                    }
                                    else if (p.Key.Equals("X-Correlation-Id", StringComparison.OrdinalIgnoreCase) && p.Value is ScalarValue svCorr && svCorr.Value is string sCorr)
                                    {
                                        var ids = sCorr.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                        <div class="clef-chips">
                                            @foreach (var id in ids)
                                            {
                                                var cid = id;
                                                <OmniButton Text="@cid" Size="ComponentSize.Sm" Variant="ButtonVariant.Link" Class="clef-mono" OnClick="@(() => OnFilter.InvokeAsync(cid))" />
                                            }
                                        </div>
                                    }
                                    else if (p.Key.Equals("EventType", StringComparison.OrdinalIgnoreCase) && p.Value is ScalarValue svType && svType.Value != null)
                                    {
                                        var et = svType.Value.ToString();
                                        <OmniButton Text="@et" Size="ComponentSize.Sm" Variant="ButtonVariant.Link" Class="clef-mono" OnClick="@(() => OnFilter.InvokeAsync(et))" />
                                    }
                                    else
                                    {
                                        <LogPropertyViewer Model="@p.Value" OnFilter="OnFilter" />
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </OmniCard>
    }
    else
    {
        <div class="clef-center">
            <OmniEmptyState Icon="file-text" Title="Selecione um log para ver os detalhes" />
        </div>
    }
</div>

@code {
    [Parameter] public ClefEvent? SelectedEvent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnFilter { get; set; }

    private async Task CopyException()
    {
        if (SelectedEvent?.Exception != null)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", TextFormatter.Format(SelectedEvent.Exception));
        }
    }
}
