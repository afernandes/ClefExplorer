@using ClefExplorer.Models
@using ClefExplorer.Services

@inject LogGroupService GroupService
@inject IFilePickerService FilePicker
@inject IJSRuntime JSRuntime
@inject DialogService Dialog

<div class="clef-groups">
    <div class="clef-groups-list">
        <OmniButton Text="Novo Grupo" Icon="plus" Variant="ButtonVariant.Ghost" Block="true" OnClick="CreateNewGroup" />
        @foreach (var group in GroupService.Groups)
        {
            var g = group;
            <div class="clef-group-item @(_editingGroup?.Id == g.Id ? "is-active" : "")" @key="g.Id" @onclick="@(() => EditGroup(g))">
                <span class="clef-mono" style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@g.Name</span>
                <OmniIcon Name="chevron-right" Size="ComponentSize.Sm" />
            </div>
        }
    </div>

    <div>
        @if (_editingGroup != null)
        {
            <div style="margin-bottom:12px;">
                <div class="clef-field-label">Nome do Grupo</div>
                <OmniTextBox Value="@_editingGroup.Name" ValueChanged="OnNameChanged" Placeholder="Ex: Logs Produção" />
            </div>

            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
                <div class="clef-field-label" style="margin:0;">Caminhos (Pastas ou Arquivos)</div>
                <OmniPopover Open="_addOpen" OpenChanged="@(v => _addOpen = v)" ShowArrow="false" Offset="4">
                    <Trigger>
                        <OmniButton Text="Adicionar" Icon="plus" Variant="ButtonVariant.Ghost" Size="ComponentSize.Sm" />
                    </Trigger>
                    <ChildContent>
                        <OmniMenu>
                            <OmniMenuItem Text="Pasta" Icon="folder" OnClick="@(() => ExecAdd(AddFolder))" />
                            <OmniMenuItem Text="Arquivo" Icon="file-text" OnClick="@(() => ExecAdd(AddFile))" />
                            <OmniMenuItem Text="Caminho Manual" Icon="edit" OnClick="@(() => ExecAdd(AddManualPath))" />
                        </OmniMenu>
                    </ChildContent>
                </OmniPopover>
            </div>

            <div class="clef-path-list">
                @foreach (var path in _editingGroup.Paths.ToList())
                {
                    var pth = path;
                    <div class="clef-tag-row" @key="pth">
                        <span class="clef-mono" title="@pth" style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@pth</span>
                        <OmniButton Icon="trash" IconOnly="true" Variant="ButtonVariant.Danger" Size="ComponentSize.Sm" OnClick="@(() => RemovePath(pth))" />
                    </div>
                }
                @if (!_editingGroup.Paths.Any())
                {
                    <div style="text-align:center; color:var(--omni-fg-muted); font-size:12px; padding:12px;">Nenhum caminho adicionado</div>
                }
            </div>

            <div class="omni-row omni-row-gap-8" style="justify-content:space-between; margin-top:16px;">
                <OmniButton Text="Excluir Grupo" Variant="ButtonVariant.Danger" OnClick="DeleteCurrentGroup" />
                <OmniButton Text="Salvar Alterações" Variant="ButtonVariant.Primary" OnClick="SaveCurrentGroup" />
            </div>
        }
        else
        {
            <div class="clef-center" style="height:100%; min-height:240px;">
                <OmniEmptyState Icon="layers" Title="Selecione ou crie um grupo" />
            </div>
        }
    </div>
</div>

@code {
    private LogGroup? _editingGroup;
    private bool _addOpen;

    private void CreateNewGroup()
    {
        _editingGroup = new LogGroup { Name = "Novo Grupo" };
    }

    private void EditGroup(LogGroup group)
    {
        // Clona para não editar o original antes de salvar.
        _editingGroup = new LogGroup
        {
            Id = group.Id,
            Name = group.Name,
            Paths = new List<string>(group.Paths)
        };
    }

    private void OnNameChanged(string? value)
    {
        if (_editingGroup != null) _editingGroup.Name = value ?? "";
    }

    /// <summary>Fecha o popover "Adicionar" e executa a ação escolhida.</summary>
    private async Task ExecAdd(Func<Task> action)
    {
        _addOpen = false;
        await action();
    }

    private async Task AddFolder()
    {
        if (_editingGroup == null) return;
        var folder = await FilePicker.PickFolderAsync();
        if (!string.IsNullOrEmpty(folder) && !_editingGroup.Paths.Contains(folder))
        {
            _editingGroup.Paths.Add(folder);
        }
    }

    private async Task AddFile()
    {
        if (_editingGroup == null) return;
        var file = await FilePicker.PickFileAsync("Arquivos CLEF (*.clef)|*.clef|Todos os arquivos (*.*)|*.*");
        if (!string.IsNullOrEmpty(file) && !_editingGroup.Paths.Contains(file))
        {
            _editingGroup.Paths.Add(file);
        }
    }

    private async Task AddManualPath()
    {
        if (_editingGroup == null) return;

        var path = await JSRuntime.InvokeAsync<string>("prompt", "Digite o caminho completo ou com variáveis de ambiente (ex: %localappdata%\\MyApp\\Logs):");

        if (!string.IsNullOrWhiteSpace(path) && !_editingGroup.Paths.Contains(path))
        {
            _editingGroup.Paths.Add(path);
        }
    }

    private void RemovePath(string path)
    {
        _editingGroup?.Paths.Remove(path);
    }

    private void SaveCurrentGroup()
    {
        if (_editingGroup == null) return;

        if (string.IsNullOrWhiteSpace(_editingGroup.Name))
        {
            return;
        }

        var existing = GroupService.Groups.FirstOrDefault(g => g.Id == _editingGroup.Id);
        if (existing != null)
        {
            GroupService.UpdateGroup(_editingGroup);
        }
        else
        {
            GroupService.AddGroup(_editingGroup);
        }

        _editingGroup = null; // Deseleciona após salvar
    }

    private async Task DeleteCurrentGroup()
    {
        if (_editingGroup == null) return;

        var ok = await Dialog.Confirm(
            $"Excluir o grupo \"{_editingGroup.Name}\"? Esta ação não pode ser desfeita.",
            "Excluir grupo",
            new ConfirmOptions { OkButtonText = "Excluir", Icon = "alert-triangle" });

        if (ok == true)
        {
            GroupService.DeleteGroup(_editingGroup.Id);
            _editingGroup = null;
        }
    }
}
