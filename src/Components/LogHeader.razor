<OmniAppBar Fixed="false">
    <OmniBrand Initial="C" Name="Clef Explorer" />

    <div class="clef-header-search">
        <OmniTextBox Value="@TextoPesquisa"
                     ValueChanged="OnSearchChanged"
                     LeadingIcon="search"
                     Clearable="true"
                     Placeholder="Pesquisar nos logs (mensagem, correlação, exceção)..." />
    </div>

    <div class="clef-header-actions">
        <OmniSelect TValue="int"
                    Value="QuantidadeRegistros"
                    ValueChanged="OnQtdChanged"
                    Items="_qtdOptions"
                    TextSelector="FormatQtd" />
        <OmniAppearanceToggle />
    </div>
</OmniAppBar>

@code {
    [Parameter] public string TextoPesquisa { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> TextoPesquisaChanged { get; set; }

    [Parameter] public int QuantidadeRegistros { get; set; }
    [Parameter] public EventCallback<int> QuantidadeRegistrosChanged { get; set; }

    [Parameter] public EventCallback OnReload { get; set; }

    private readonly int[] _qtdOptions = { 30, 50, 100 };

    private static string FormatQtd(int v) => $"{v} itens";

    private async Task OnSearchChanged(string? v)
    {
        TextoPesquisa = v ?? string.Empty;
        await TextoPesquisaChanged.InvokeAsync(TextoPesquisa);
    }

    private async Task OnQtdChanged(int v)
    {
        QuantidadeRegistros = v;
        await QuantidadeRegistrosChanged.InvokeAsync(v);
    }
}
