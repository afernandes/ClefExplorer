@using System.IO
@using System.Text.RegularExpressions

@if (RootNodes.Any())
{
    <OmniTree Data="RootNodes"
              AllowCheckboxes="true"
              CheckedValues="_checkedNodes"
              CheckedValuesChanged="OnCheckedChanged">
        <OmniTreeLevel Text="@(o => ((FileTreeNode)o).Name)"
                       Children="@(o => ((FileTreeNode)o).Children)"
                       HasChildren="@(o => ((FileTreeNode)o).Children.Count > 0)"
                       Expanded="@(o => true)"
                       Icon="@(o => NodeIcon((FileTreeNode)o))">
            <Template Context="item">
                @{ var bk = item.Value is FileTreeNode fn && fn.IsBackup; }
                @if (!string.IsNullOrEmpty(item.Icon))
                {
                    <OmniIcon Name="@item.Icon" Size="ComponentSize.Sm" Class="@(bk ? "omni-tree-icon clef-tree-backup" : "omni-tree-icon")" />
                }
                <span class="@(bk ? "omni-tree-text clef-tree-backup" : "omni-tree-text")">@item.Text</span>
            </Template>
        </OmniTreeLevel>
    </OmniTree>
}
else
{
    <div class="clef-center" style="height:auto; padding:16px;">
        <span style="font-size:12px;">Nenhum arquivo carregado</span>
    </div>
}

@code {
    [Parameter] public IEnumerable<string> Files { get; set; } = Enumerable.Empty<string>();
    [Parameter] public IEnumerable<string> CheckedFiles { get; set; } = Enumerable.Empty<string>();
    [Parameter] public EventCallback<HashSet<string>> OnSelectionChanged { get; set; }

    private List<FileTreeNode> RootNodes { get; set; } = new();
    private List<object> _checkedNodes = new();
    private List<string>? _lastFiles;

    protected override void OnParametersSet()
    {
        var currentFiles = Files?.OrderBy(f => f).ToList() ?? new List<string>();
        bool filesChanged = _lastFiles == null || !currentFiles.SequenceEqual(_lastFiles);

        // Só (re)derivamos o estado dos checkboxes quando a ÁRVORE muda (novo
        // conjunto de arquivos). Durante a interação, o OmniTree é a fonte única
        // do estado de marcação — re-derivar a cada eco de CheckedFiles
        // dessincronizava pais/filhos (ex.: pasta marcada sem nenhum filho).
        if (filesChanged)
        {
            _lastFiles = currentFiles;
            var currentChecked = CheckedFiles != null
                ? new HashSet<string>(CheckedFiles, StringComparer.OrdinalIgnoreCase)
                : new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            BuildTree();
            _checkedNodes = ComputeChecked(currentChecked);
        }
    }

    private static string NodeIcon(FileTreeNode node)
    {
        if (node.IsBackup) return "archive";
        if (!string.IsNullOrEmpty(node.FullPath)) return "file-text";
        return "folder";
    }

    // Marca as folhas presentes em checkedFiles e os nós cujos descendentes (e o
    // próprio arquivo, se houver) estejam todos marcados — reproduz o estado
    // tri-state inicial (OmniTree calcula o indeterminate dos demais a partir disso).
    private List<object> ComputeChecked(HashSet<string> checkedFiles)
    {
        var result = new List<object>();
        bool Walk(FileTreeNode n)
        {
            var hasFile = !string.IsNullOrEmpty(n.FullPath);

            // Folha pura: marcada sse o arquivo está carregado.
            if (n.Children.Count == 0)
            {
                var on = hasFile && checkedFiles.Contains(n.FullPath!);
                if (on) result.Add(n);
                return on;
            }

            // Nó com filhos. IMPORTANTE: um nó pode ser arquivo E pasta ao mesmo
            // tempo (ex.: "Fiscal.clef" + "Fiscal.Zeus.*.clef" → nó "Fiscal" com
            // FullPath e Children). Avaliamos TODOS os filhos (para marcá-los
            // individualmente) e só consideramos o nó "marcado" se todos os filhos
            // E o próprio arquivo (quando existir) estiverem marcados — senão fica
            // indeterminado, evitando o bug de "pasta marcada sem filhos".
            bool all = true;
            foreach (var c in n.Children) all &= Walk(c);
            if (hasFile) all &= checkedFiles.Contains(n.FullPath!);
            if (all) result.Add(n);
            return all;
        }
        foreach (var root in RootNodes) Walk(root);
        return result;
    }

    private async Task OnCheckedChanged(IEnumerable<object> checkedNodes)
    {
        _checkedNodes = checkedNodes.ToList();
        var files = _checkedNodes
            .OfType<FileTreeNode>()
            .Where(n => !string.IsNullOrEmpty(n.FullPath))
            .Select(n => n.FullPath!);
        var set = new HashSet<string>(files, StringComparer.OrdinalIgnoreCase);
        await OnSelectionChanged.InvokeAsync(set);
    }

    // ─── Construção da árvore virtual (lógica preservada da versão Bootstrap) ───

    private void BuildTree()
    {
        RootNodes.Clear();

        if (_lastFiles == null || !_lastFiles.Any()) return;

        var commonSegments = GetCommonPathSegments(_lastFiles);

        foreach (var file in _lastFiles)
        {
            var pathParts = GetVirtualPathParts(file, commonSegments);
            AddNodeToTree(RootNodes, pathParts, file);
        }

        SortNodes(RootNodes);
        CollapseSingleChildNodes(RootNodes);
        SplitFileAndFolderNodes(RootNodes);
        PromoteBackupToRoot();
    }

    // Move os nós "Backup" para o nível raiz, no início da árvore (fora de "Logs"),
    // marcando-os para receberem ícone/cor próprios (reforço visual de backup).
    private void PromoteBackupToRoot()
    {
        var backups = new List<FileTreeNode>();

        void Collect(List<FileTreeNode> nodes)
        {
            for (int i = nodes.Count - 1; i >= 0; i--)
            {
                var n = nodes[i];
                if (string.IsNullOrEmpty(n.FullPath) &&
                    string.Equals(n.Name, "Backup", StringComparison.OrdinalIgnoreCase))
                {
                    n.IsBackup = true;
                    n.Parent = null;
                    backups.Add(n);
                    nodes.RemoveAt(i);
                }
                else
                {
                    Collect(n.Children);
                }
            }
        }

        Collect(RootNodes);

        // Insere no início, preservando a ordem original.
        backups.Reverse();
        for (int i = 0; i < backups.Count; i++)
        {
            RootNodes.Insert(i, backups[i]);
        }
    }

    // Quando um nó é arquivo E pasta ao mesmo tempo (existe um log cujo nome é
    // prefixo de outros — ex.: "...Fiscal.clef" + "...Fiscal.Zeus.*.clef"),
    // extrai o arquivo próprio para um sub-item folha, permitindo selecioná-lo/
    // exibi-lo isoladamente. O nó passa a ser uma pasta pura.
    private void SplitFileAndFolderNodes(List<FileTreeNode> nodes)
    {
        foreach (var node in nodes)
        {
            SplitFileAndFolderNodes(node.Children);

            if (!string.IsNullOrEmpty(node.FullPath) && node.Children.Count > 0)
            {
                var ownFile = new FileTreeNode
                {
                    Name = node.Name,
                    FullPath = node.FullPath,
                    Parent = node
                };
                node.FullPath = null;          // o nó vira pasta pura
                node.Children.Insert(0, ownFile); // o arquivo próprio aparece primeiro
            }
        }
    }

    private string[] GetCommonPathSegments(List<string> files)
    {
        if (files.Count == 0) return Array.Empty<string>();

        var commonSegments = GetDirSegments(files[0]);

        foreach (var file in files.Skip(1))
        {
            var segments = GetDirSegments(file);
            int matchLength = 0;
            int minLen = Math.Min(commonSegments.Length, segments.Length);

            for (int i = 0; i < minLen; i++)
            {
                if (string.Equals(commonSegments[i], segments[i], StringComparison.OrdinalIgnoreCase))
                    matchLength++;
                else
                    break;
            }

            if (matchLength < commonSegments.Length)
                commonSegments = commonSegments.Take(matchLength).ToArray();

            if (commonSegments.Length == 0) break;
        }

        return commonSegments;
    }

    private string[] GetDirSegments(string path)
    {
        var dir = Path.GetDirectoryName(path);
        if (string.IsNullOrEmpty(dir)) return Array.Empty<string>();
        return dir.Split(new[] { Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar }, StringSplitOptions.RemoveEmptyEntries);
    }

    private List<string> GetVirtualPathParts(string file, string[] commonSegments)
    {
        var isGz = file.EndsWith(".gz", StringComparison.OrdinalIgnoreCase);
        var fileName = Path.GetFileName(file);

        var fileSegments = GetDirSegments(file);
        var skipCount = Math.Max(0, commonSegments.Length - 1);
        var pathParts = fileSegments.Skip(skipCount).ToList();

        string cleanName;

        if (isGz)
        {
            var match = Regex.Match(fileName, @"(?:^|\.)log(\d{4})(\d{2})(\d{2})\.clef\.gz$", RegexOptions.IgnoreCase);
            if (match.Success)
            {
                pathParts.Add(match.Groups[1].Value); // Year
                pathParts.Add(match.Groups[2].Value); // Month
                pathParts.Add(match.Groups[3].Value); // Day

                cleanName = Regex.Replace(fileName, @"(?:^|\.)log\d+\.clef\.gz$", "", RegexOptions.IgnoreCase);
                if (string.IsNullOrWhiteSpace(cleanName)) cleanName = "log";
            }
            else
            {
                cleanName = Path.GetFileNameWithoutExtension(Path.GetFileNameWithoutExtension(fileName));
            }
        }
        else
        {
            cleanName = Regex.Replace(fileName, @"\.log\d+\.clef$", "", RegexOptions.IgnoreCase);
            if (cleanName.EndsWith(".clef", StringComparison.OrdinalIgnoreCase))
            {
                cleanName = Path.GetFileNameWithoutExtension(cleanName);
            }
        }

        var nameParts = cleanName.Split('.');
        if (nameParts.Length > 1)
        {
            pathParts.AddRange(nameParts.Take(nameParts.Length - 1));
            fileName = nameParts.Last();
        }
        else
        {
            fileName = cleanName;
        }

        pathParts.Add(fileName);
        return pathParts;
    }

    private void AddNodeToTree(List<FileTreeNode> currentLevel, List<string> pathParts, string fullPath)
    {
        FileTreeNode? parent = null;

        for (int i = 0; i < pathParts.Count; i++)
        {
            var part = pathParts[i];
            var isLast = i == pathParts.Count - 1;

            var currentNode = currentLevel.FirstOrDefault(n => n.Name.Equals(part, StringComparison.OrdinalIgnoreCase));
            if (currentNode == null)
            {
                currentNode = new FileTreeNode
                {
                    Name = part,
                    Parent = parent
                };
                currentLevel.Add(currentNode);
            }

            if (isLast)
            {
                currentNode.FullPath = fullPath;
            }

            parent = currentNode;
            currentLevel = currentNode.Children;
        }
    }

    private void CollapseSingleChildNodes(List<FileTreeNode> nodes)
    {
        for (int i = 0; i < nodes.Count; i++)
        {
            var node = nodes[i];
            while (string.IsNullOrEmpty(node.FullPath) &&
                   node.Children.Count == 1 &&
                   string.IsNullOrEmpty(node.Children[0].FullPath))
            {
                node = node.Children[0];
            }
            nodes[i] = node;
            nodes[i].Parent = null;
        }
    }

    private void SortNodes(List<FileTreeNode> nodes)
    {
        // Pastas primeiro, depois arquivos; ambos em ordem alfabética.
        nodes.Sort((a, b) =>
        {
            var aIsFolder = a.Children.Any();
            var bIsFolder = b.Children.Any();

            if (aIsFolder && !bIsFolder) return -1;
            if (!aIsFolder && bIsFolder) return 1;

            return string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase);
        });

        foreach (var node in nodes)
        {
            SortNodes(node.Children);
        }
    }

    public class FileTreeNode
    {
        public string Name { get; set; } = "";
        public string? FullPath { get; set; }
        public List<FileTreeNode> Children { get; set; } = new();
        public FileTreeNode? Parent { get; set; }
        public bool IsBackup { get; set; }
    }
}
